{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,

    "allowJs": true,
    "checkJs": false,

    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,

    "outDir": "dist"
  },
  "include": [
    "index.js",
    "api/**/*.js",
    "src/ts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
